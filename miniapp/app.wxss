page {
  background: linear-gradient(180deg, #fcfaf6 0%, #f4efe4 100%);
  color: #2f2a24;
  font-family: "PingFang SC", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 252, 246, 0.96);
  border: 1rpx solid rgba(108, 101, 91, 0.14);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(117, 88, 49, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
}

.section-subtitle {
  font-size: 24rpx;
  color: #7a7268;
}

.primary-btn,
.secondary-btn {
  height: 84rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn {
  background: linear-gradient(135deg, #d98f3c, #b86a2b);
  color: #fffaf2;
}

.secondary-btn {
  background: #efe5d2;
  color: #8b5520;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-label {
  font-size: 26rpx;
  color: #6c655b;
}

.input,
.textarea {
  width: 100%;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(108, 101, 91, 0.14);
  box-sizing: border-box;
}

.input {
  height: 84rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 24rpx;
}

.pill {
  display: inline-flex;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f4ead9;
  color: #8b5520;
  font-size: 24rpx;
}

.empty {
  padding: 48rpx 0;
  color: #92887a;
  text-align: center;
  font-size: 26rpx;
}
