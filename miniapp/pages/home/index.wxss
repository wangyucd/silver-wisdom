.home-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.banner-card,
.section-card {
  padding: 28rpx;
}

.scroll-tags {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.pill-active {
  background: #d98f3c;
  color: #fffaf2;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.assistant-link {
  width: 180rpx;
  height: 68rpx;
  font-size: 24rpx;
}

.hotspot-item,
.content-item {
  padding: 24rpx 0;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(108, 101, 91, 0.14);
}

.hotspot-item:last-child,
.content-item:last-child {
  border-bottom: 0;
}

.hotspot-title,
.content-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.meta-text,
.heat-score {
  color: #8d816f;
  font-size: 24rpx;
}
